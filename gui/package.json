{
  "name": "gui",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "webpack serve --open",
    "build": "webpack",
    "electron": "NODE_ENV=development electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Alessandro Talmi <alessandro.talmi@gmail.com>",
  "homepage": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "build": {
    "appId": "com.example.todo",
    "productName": "Worker",
    "files": [
      "dist/**/*",
      "icon.png",
      "main.js"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "extraFiles": [
      "dist"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    }
  }
}
