{
  "name": "gui",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "webpack serve --open",
    "build": "webpack",
    "electron": "NODE_ENV=development electron .",
    "dist": "electron-builder",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "keywords": [],
  "author": "Alessandro Talmi <alessandro.talmi@gmail.com>",
  "homepage": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^7.1.2",
    "electron": "^31.3.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "build": {
    "appId": "com.example.todo",
    "productName": "Worker",
    "files": [
      "dist/**/*",
      "icon.png",
      "main.js"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "extraFiles": [
      "dist"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "WorkerGui-${arch}.${ext}"
    }
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "extraResource": [
          "dist/bundle.js",
          "dist/index.html",
          "scripts"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-deb",
          "config": {
            "options": {
              "name": "todo.package",
              "productName": "Worker2",
              "maintainer": "Alessandro Talmi <alessandro.talmi@gmail.com>",
              "homepage": "https://il-tuo-sito-web.com",
              "description" : "TODO a description",
              "version": "0.1.0",
              "depends": ["podman"]
            }
          }
        }
      ]
    }
  }
}
